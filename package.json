{
  "name": "gatepass",
  "version": "0.0.0",
  "private": true,
  "description": "Precision AppSec platform for the AI-native stack",
  "type": "module",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc --build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --build --noEmit || tsc -p tsconfig.base.json --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "corpus:measure": "tsx corpus/harness/cli.ts",
    "scan": "tsx cli/src/index.ts"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.10.5",
    "eslint": "^9.17.0",
    "prettier": "^3.9.4",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.63.0",
    "vite": "^6",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "zod": "^3.24.1"
  }
}
