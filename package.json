{
  "name": "gatepass",
  "version": "0.0.0",
  "private": true,
  "description": "Precision AppSec platform for the AI-native stack",
  "type": "module",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc --build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "benchmark": "vitest run benchmark/test/introspection-benchmark.test.ts --reporter=verbose",
    "benchmark:full": "vitest run benchmark/test/ --reporter=verbose",
    "benchmark:ci": "GATE_PASS_TEST_REPO=${GATE_PASS_TEST_REPO:-../../gate_pass_test_repo} vitest run benchmark/test/introspection-benchmark.test.ts benchmark/test/edge-cases.test.ts --reporter=verbose",
    "benchmark:with-llm": "NVIDIA_API_KEY=${NVIDIA_API_KEY:?Set NVIDIA_API_KEY for LLM refinement} vitest run benchmark/test/introspection-benchmark.test.ts --reporter=verbose",
    "benchmark:production": "NVIDIA_API_KEY=${NVIDIA_API_KEY:-\"\"} vitest run benchmark/test/production-readiness.test.ts --reporter=verbose",
    "benchmark:incumbent": "tsx benchmark/src/run-incumbent.ts",
    "corpus:measure": "tsx corpus/harness/cli.ts",
    "corpus:publish": "tsx corpus/harness/publish.ts",
    "db:migrate": "tsx packages/shared/db/migrate.ts",
    "scan": "tsx cli/src/index.ts"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.10.5",
    "eslint": "^9.17.0",
    "prettier": "^3.9.4",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.63.0",
    "vite": "^6",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "zod": "^3.24.1"
  }
}
