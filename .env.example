# Database
DATABASE_URL=postgres://gatepass:gatepass@localhost:5432/gatepass
REDIS_URL=redis://localhost:6379

# GitHub App (dev credentials — private key stored at the path below)
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY_PATH=
GITHUB_INSTALLATION_ID=
GITHUB_WEBHOOK_SECRET=

# LLM gateway (research-tier semantic analysis, zero-retention)
ANTHROPIC_API_KEY=
GATEPASS_LLM_ENABLED=true

# Introspection benchmark
#   pnpm benchmark
# Scans the test repo at ~/documents/YC/gate_pass_test_repo/ (or GATE_PASS_TEST_REPO)
# and reports per-class TP/FP. When ANTHROPIC_API_KEY is set above, the benchmark
# uses runScanAsync to exercise the LLM gateway for confidence refinement.
# Both paths (with and without the key) produce the same TP/FP results — the
# key only affects research-tier confidence scoring.

# Object storage (scan artifacts)
S3_BUCKET=
S3_REGION=
