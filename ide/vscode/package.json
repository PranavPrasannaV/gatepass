{
  "name": "gatepass-vscode",
  "displayName": "Gatepass",
  "description": "Show Gatepass findings inline in your editor.",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "engines": {
    "vscode": "^1.125.0"
  },
  "categories": [
    "Linters"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "gatepass.showFindings",
        "title": "Gatepass: Load findings into Problems"
      }
    ],
    "configuration": {
      "title": "Gatepass",
      "properties": {
        "gatepass.findingsPath": {
          "type": "string",
          "default": "gatepass.findings.json",
          "description": "Path (relative to the workspace root) of the findings JSON to display."
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "package": "vsce package --no-dependencies"
  },
  "dependencies": {
    "@gatepass/findings": "workspace:*"
  },
  "devDependencies": {
    "@types/vscode": "^1.125.0",
    "@vscode/vsce": "^3.9.2",
    "esbuild": "^0.28.1"
  }
}
